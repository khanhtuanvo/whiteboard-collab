NODE_ENV=production
PORT=4000

# Database
DATABASE_URL=mysql://whiteboard_user:your_db_password@mysql:3306/whiteboard

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Frontend origin (used for CORS)
FRONTEND_URL=http://localhost

# ML service (local dev defaults to localhost; Docker overrides this in compose)
ML_SERVICE_URL=http://localhost:5000
ML_SERVICE_KEY=replace_with_a_random_secret

# AWS S3 (optional — for file uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET=
