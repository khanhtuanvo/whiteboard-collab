# Copy this file to .env and fill in the values before running docker compose up.

# ── MySQL ────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=changeme_root
MYSQL_USER=whiteboard_user
MYSQL_PASSWORD=changeme_db

# ── Backend ──────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=7d
# Origin that the backend allows for CORS (must match what users browse to)
FRONTEND_URL=http://localhost

# ── Frontend (baked into the Next.js bundle at build time) ───────────────────
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_WS_URL=http://localhost

# ── ML Service (shared secret between backend and ml-service) ────────────────
# Generate with: openssl rand -hex 32
ML_ENABLED=true
# Optional: backend wait time before degrading AI response when ML is slow/down
ML_TIMEOUT_MS=8000
ML_SERVICE_KEY=replace_with_a_random_secret

# ── AWS S3 (optional — leave empty to disable file uploads) ──────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET=
